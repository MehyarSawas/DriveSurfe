APP_URL=https://your-domain.com
APP_ENV=production

# Must be a strong random string (min 32 chars): openssl rand -hex 32
SESSION_KEY=change-this-to-a-random-32-char-string

# One-time token to register the first passkey device — keep this secret
REGISTRATION_TOKEN=change-this-to-a-random-secret-token

KDRIVE_DRIVE_ID=your_kdrive_drive_id
KDRIVE_TOKEN=your_kdrive_api_token

# Optional: restrict the Timeline (media stream + month index) to one folder
# (recursively) instead of the whole drive. Numeric kDrive folder ID.
#TIMELINE_FOLDER_ID=12345
