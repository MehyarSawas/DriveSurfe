RewriteEngine On
RewriteBase /

# Route API requests to index.php
RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^ index.php [L]

# SPA fallback — serve index.html for all non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# MIME types for PWA
AddType application/manifest+json .webmanifest
AddType application/javascript .js
AddType text/javascript .mjs

# Service worker must be served without cache
<FilesMatch "ngsw\.json|ngsw-worker\.js|safety-worker\.js|preview-sw\.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

# index.html must always revalidate: it carries the CSP header and references
# the hashed bundle filenames — a cached copy replays stale headers and stale
# bundle URLs (this caused styles/icons to stay broken after a CSP fix was
# already deployed). Hashed assets (*-HASH.js/css) are immutable and cache fine.
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# NOTE: Do NOT set a Content-Security-Policy header here — this host mangles
# it and breaks stylesheet/font loading (verified in production by bisection:
# styles broke with the header present, recovered the moment it was removed).
# The SPA's CSP is delivered via <meta http-equiv> in index.html instead.
# frame-ancestors can't be expressed in a meta CSP, so block framing with the
# short, host-safe X-Frame-Options header (same mechanism as the working
# Cache-Control headers below).
Header set X-Frame-Options "DENY"
