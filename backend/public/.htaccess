RewriteEngine On
RewriteBase /

# Route API requests to index.php
RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^ index.php [L]

# SPA fallback — serve index.html for all non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# MIME types for PWA
AddType application/manifest+json .webmanifest
AddType application/javascript .js
AddType text/javascript .mjs

# Service worker must be served without cache
<FilesMatch "ngsw\.json|ngsw-worker\.js|safety-worker\.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

# Content-Security-Policy for the SPA — deliberately minimal. It locks the
# actual attack vector (script execution: only same-origin scripts run, no
# CDN/injected/inline scripts, no plugins, no <base> hijack, no framing) and
# leaves rendering resources (styles, fonts, images, media, workers)
# unrestricted, since a stricter resource policy broke styles/fonts in
# production on this host. OpenCV.js is self-hosted (assets/opencv/), which
# is what makes script-src 'self' sufficient.
Header always set Content-Security-Policy "script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
