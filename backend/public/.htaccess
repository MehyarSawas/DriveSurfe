RewriteEngine On
RewriteBase /

# Route API requests to index.php
RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^ index.php [L]

# SPA fallback — serve index.html for all non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# MIME types for PWA
AddType application/manifest+json .webmanifest
AddType application/javascript .js
AddType text/javascript .mjs

# Service worker must be served without cache
<FilesMatch "ngsw\.json|ngsw-worker\.js|safety-worker\.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

# Content-Security-Policy for the SPA. OpenCV.js is self-hosted only
# (assets/opencv/opencv.js, no remote CDN fallback — see opencv-loader.ts),
# so script-src/connect-src need no third-party script host. Google Fonts CSS
# is still loaded remotely (index.html), hence style-src/font-src allowances.
Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
